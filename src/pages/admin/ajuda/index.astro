---
/**
 * admin/ajuda/index.astro
 *
 * Central de Ajuda do painel admin.
 * Guia completo: primeiros passos, funcionalidades do CMS, atualizações e solução de problemas.
 * Pensado para usuários leigos, com linguagem simples e orientações passo a passo.
 */

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAdminSiteMode } from '../../../utils/admin-site-mode';
import { getEntry } from 'astro:content';

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteMode = getAdminSiteMode(Astro.cookies, settings);
const isLocal = siteMode === 'local';
---

<AdminLayout title="Ajuda — CNX Agency Admin">
    <div class="max-w-4xl">

        <div class="mb-8">
            <h1 class="text-3xl font-heading font-bold text-[#e5e5e5] mb-2">Central de Ajuda</h1>
            <p class="text-[#a3a3a3]">Tudo o que você precisa para usar o CNX com confiança.</p>
        </div>

        <!-- Navegação por seções -->
        <div class="flex flex-wrap gap-2 mb-8 pb-6" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
            <a href="#primeiros-passos" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors" style="background: rgba(99,102,241,0.15); color: var(--primary, #6366f1); border: 1px solid rgba(99,102,241,0.3);">
                🚀 Primeiros passos
            </a>
            <a href="#funcionalidades" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors hover:bg-[rgba(255,255,255,0.05)]" style="color: #a3a3a3; border: 1px solid rgba(255,255,255,0.1);">
                📋 O que cada coisa faz
            </a>
            <a href="#atualizacoes" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors hover:bg-[rgba(255,255,255,0.05)]" style="color: #a3a3a3; border: 1px solid rgba(255,255,255,0.1);">
                🔄 Atualizações
            </a>
            <a href="#problemas" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors hover:bg-[rgba(255,255,255,0.05)]" style="color: #a3a3a3; border: 1px solid rgba(255,255,255,0.1);">
                🔧 Solução de problemas
            </a>
        </div>

        <!-- Seção 1: Primeiros passos -->
        <section id="primeiros-passos" class="admin-card p-6 mb-8">
            <h2 class="text-xl font-bold text-[#e5e5e5] mb-4">🚀 Primeiros passos</h2>
            <p class="text-[#a3a3a3] text-sm mb-6">
                Faça estes ajustes logo após configurar seu site para garantir que tudo funcione bem.
            </p>

            <div class="space-y-6">
                <div class="p-4 rounded-lg" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
                    <h3 class="font-semibold text-[#e5e5e5] mb-2">1. Trocar e-mail e senha do admin</h3>
                    <p class="text-sm text-[#a3a3a3] mb-2">Por segurança, altere as credenciais padrão.</p>
                    <p class="text-sm text-[#a3a3a3]">Vá em <a href="/admin/authors" class="text-indigo-400 hover:underline">Autores</a> → clique no usuário &quot;Administrador&quot; → altere e-mail e senha → Salvar.</p>
                </div>

                <div class="p-4 rounded-lg" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
                    <h3 class="font-semibold text-[#e5e5e5] mb-2">2. Alterar nome do site</h3>
                    <p class="text-sm text-[#a3a3a3]">Em <a href="/admin/configuracoes" class="text-indigo-400 hover:underline">Configurações</a> você define o nome que aparece no site.</p>
                </div>

                <div class="p-4 rounded-lg" style="background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.25);">
                    <h3 class="font-semibold text-[#22c55e] mb-2">3. Ativar atualizações automáticas (obrigatório)</h3>
                    <p class="text-sm text-[#fbbf24] mb-2">⚠️ Sem isso, o botão &quot;Aplicar agora&quot; no banner de atualização retornará erro.</p>
                    <p class="text-sm text-[#a3a3a3] mb-3">
                        Para receber melhorias do template sem baixar nada de novo, ative as permissões do GitHub:
                    </p>
                    <ol class="text-sm text-[#a3a3a3] list-decimal list-inside space-y-2 ml-2">
                        <li>Acesse seu repositório no GitHub</li>
                        <li>Clique em <strong class="text-[#e5e5e5]">Settings</strong> (Configurações)</li>
                        <li>No menu lateral: <strong class="text-[#e5e5e5]">Actions</strong> → <strong class="text-[#e5e5e5]">General</strong></li>
                        <li>Em &quot;Workflow permissions&quot;, marque <strong class="text-[#e5e5e5]">Read and write permissions</strong></li>
                        <li>Marque <strong class="text-[#e5e5e5]">Allow GitHub Actions to create and approve pull requests</strong></li>
                        <li>Clique em <strong class="text-[#e5e5e5]">Save</strong></li>
                    </ol>
                    <p class="text-xs text-[#737373] mt-3">Isso é feito uma única vez. Depois, as atualizações funcionam com 1 clique no painel.</p>
                </div>
            </div>
        </section>

        <!-- Seção 2: Funcionalidades -->
        <section id="funcionalidades" class="admin-card p-6 mb-8">
            <h2 class="text-xl font-bold text-[#e5e5e5] mb-4">📋 O que cada coisa faz</h2>
            <p class="text-[#a3a3a3] text-sm mb-6">
                Entenda cada área do painel para aproveitar ao máximo o CMS.
            </p>

            <div class="space-y-4">
                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-1">Dashboard</h3>
                    <p class="text-sm text-[#a3a3a3]">Visão geral do site: posts recentes, estatísticas e ações rápidas.</p>
                </div>
                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-1">Posts</h3>
                    <p class="text-sm text-[#a3a3a3]">Crie e edite artigos do blog. Defina título, conteúdo, categoria e data de publicação.</p>
                </div>
                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-1">Autores</h3>
                    <p class="text-sm text-[#a3a3a3]">Contas que podem acessar o painel. Edite e-mail, senha e perfil.</p>
                </div>
                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-1">Categorias</h3>
                    <p class="text-sm text-[#a3a3a3]">Organize os posts por tema (ex: Dicas, Novidades).</p>
                </div>
                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-1">Páginas</h3>
                    <p class="text-sm text-[#a3a3a3]">Edite a Home, Menu, Footer, Sobre, Contato e outras páginas fixas.</p>
                </div>
                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-1">Mídia</h3>
                    <p class="text-sm text-[#a3a3a3]">Envie e gerencie imagens. Use nos posts e nas páginas.</p>
                </div>
                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-1">Configurações</h3>
                    <p class="text-sm text-[#a3a3a3]">IA para gerar conteúdo, SEO (sitemap, robots.txt) e dados de contato (telefone e WhatsApp centralizados).</p>
                </div>

                {isLocal && (
                    <div class="pt-4 mt-4" style="border-top: 1px solid rgba(255,255,255,0.08);">
                        <h3 class="font-semibold text-[#10b981] mb-3">Modo Local — recursos extras</h3>
                        <ul class="text-sm text-[#a3a3a3] space-y-2">
                            <li><strong class="text-[#e5e5e5]">Page Generator:</strong> Keywords, bairros e páginas para SEO local.</li>
                            <li><strong class="text-[#e5e5e5]">Template:</strong> Escolha um template de nicho (ex: encanador, eletricista).</li>
                            <li><strong class="text-[#e5e5e5]">Home Local:</strong> Edite textos, NAP e serviços em destaque.</li>
                            <li><strong class="text-[#e5e5e5]">Contato:</strong> Configure telefone e WhatsApp em Configurações → Contato.</li>
                        </ul>
                    </div>
                )}
            </div>
        </section>

        <!-- Seção 3: Atualizações -->
        <section id="atualizacoes" class="admin-card p-6 mb-8">
            <h2 class="text-xl font-bold text-[#e5e5e5] mb-4">🔄 Atualizações</h2>
            <p class="text-[#a3a3a3] text-sm mb-6">
                O CNX recebe melhorias e correções. Saiba como atualizar sem perder nada.
            </p>

            <div class="p-4 rounded-lg mb-6" style="background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.25);">
                <p class="text-sm text-[#86efac] font-medium mb-2">✅ Seus posts, imagens e configurações não são alterados.</p>
                <p class="text-sm text-[#a3a3a3]">Apenas o código do template é atualizado. Seu conteúdo fica intacto.</p>
            </div>

            <div class="space-y-4">
                <h3 class="font-semibold text-[#e5e5e5]">Como atualizar</h3>
                <p class="text-sm text-[#a3a3a3]">
                    Quando houver uma nova versão, um banner amarelo aparece no topo do painel. Clique em <strong class="text-[#e5e5e5]">&quot;Quero as melhorias&quot;</strong> ou <strong class="text-[#e5e5e5]">&quot;Aplicar agora&quot;</strong>.
                </p>
                <p class="text-sm text-[#a3a3a3]">
                    Em até 2 minutos seu site estará atualizado. Você pode continuar usando o painel normalmente.
                </p>
                <p class="text-xs text-[#737373] mt-2">
                    Se as atualizações não funcionarem, confira se você fez o passo 3 da seção &quot;Primeiros passos&quot; (permissões do GitHub).
                </p>
            </div>
        </section>

        <!-- Seção 4: Solução de problemas -->
        <section id="problemas" class="admin-card p-6 mb-8">
            <h2 class="text-xl font-bold text-[#e5e5e5] mb-4">🔧 Solução de problemas</h2>

            <div class="space-y-6">
                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-2">Esqueci a senha</h3>
                    <p class="text-sm text-[#a3a3a3]">
                        Na Vercel, edite a variável <strong class="text-[#e5e5e5]">ADMIN_SECRET</strong> com uma nova senha e salve. Use <code class="px-1.5 py-0.5 rounded bg-[rgba(255,255,255,0.1)] text-xs">admin@admin.com</code> + a nova senha.
                    </p>
                </div>

                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-2">Site abre em branco ou erro 500</h3>
                    <p class="text-sm text-[#a3a3a3]">
                        Veja os logs na Vercel: Projeto → Deployments → último deploy. Geralmente é variável de ambiente ausente ou incorreta.
                    </p>
                </div>

                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-2">Atualizações não chegam</h3>
                    <p class="text-sm text-[#a3a3a3]">
                        Confirme que fez o passo 3 dos &quot;Primeiros passos&quot;. Em Actions no GitHub, verifique se o workflow &quot;Atualizar Template CNX&quot; rodou sem erros.
                    </p>
                </div>

                <div>
                    <h3 class="font-semibold text-[#e5e5e5] mb-2">Erro ao salvar</h3>
                    <p class="text-sm text-[#a3a3a3]">
                        Verifique se <strong class="text-[#e5e5e5]">GITHUB_TOKEN</strong>, <strong class="text-[#e5e5e5]">GITHUB_OWNER</strong> e <strong class="text-[#e5e5e5]">GITHUB_REPO</strong> estão corretos nas variáveis de ambiente da Vercel.
                    </p>
                </div>
            </div>

            <p class="text-sm text-[#737373] mt-6">
                Ainda com dúvidas? Consulte o <a href="https://8linksapp-maker.github.io/cnx" target="_blank" rel="noopener" class="text-indigo-400 hover:underline">FAQ completo</a> ou entre em contato com o suporte.
            </p>
        </section>

    </div>
</AdminLayout>
