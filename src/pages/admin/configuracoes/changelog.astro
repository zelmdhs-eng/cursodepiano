---
/**
 * admin/configuracoes/changelog.astro
 *
 * Página dedicada ao Changelog do template CNX.
 * Busca o CHANGELOG.md do repositório oficial e exibe o histórico de atualizações.
 * Separado de IA/SEO/Contato por ser leitura, não configuração.
 */

import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Changelog — CNX Agency Admin">
    <div class="max-w-3xl">
        <div class="mb-6">
            <a href="/admin/configuracoes" class="text-sm text-[#737373] hover:text-indigo-400 transition-colors inline-flex items-center gap-1 mb-4">
                ← Voltar para Configurações
            </a>
            <h1 class="text-3xl font-heading font-bold text-[#e5e5e5] mb-2">Changelog</h1>
            <p class="text-[#a3a3a3] text-sm">Histórico de melhorias e correções do template. Toda vez que você atualiza, novas entradas aparecem aqui.</p>
        </div>

        <div class="admin-card p-6">
            <div id="changelog-version" class="text-xs text-[#737373] mb-4" style="display: none;"></div>
            <div
                id="changelog-content"
                class="changelog-prose text-sm text-[#a3a3a3]"
                style="min-height: 120px;"
            >
                <p class="text-[#71717a]">Carregando changelog...</p>
            </div>
        </div>
    </div>
</AdminLayout>

<style>
    .changelog-prose h2 { font-size: 1rem; font-weight: 700; color: #e5e5e5; margin-top: 1.5rem; margin-bottom: 0.75rem; }
    .changelog-prose h3 { font-size: 0.875rem; font-weight: 600; color: #e5e5e5; margin-top: 1rem; margin-bottom: 0.5rem; }
    .changelog-prose ul { margin: 0.5rem 0; padding-left: 1.25rem; }
    .changelog-prose li { margin: 0.25rem 0; color: #a3a3a3; }
    .changelog-prose a { color: #818cf8; text-decoration: none; }
    .changelog-prose a:hover { text-decoration: underline; }
    .changelog-prose p { margin: 0.5rem 0; color: #a3a3a3; }
    .changelog-prose hr { border-color: rgba(255,255,255,0.08); margin: 1rem 0; }
</style>

<script is:inline>
    (function() {
        var container = document.getElementById('changelog-content');
        var versionEl = document.getElementById('changelog-version');
        if (!container) return;
        fetch('/api/admin/changelog')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.html) {
                    container.innerHTML = data.html;
                    container.classList.add('changelog-prose');
                }
                if (data.installedVersion && versionEl) {
                    versionEl.textContent = 'Sua versão atual: v' + data.installedVersion;
                    versionEl.style.display = 'block';
                }
            })
            .catch(function() {
                container.innerHTML = '<p class="text-[#71717a]">Não foi possível carregar o changelog. Tente novamente mais tarde.</p>';
            });
    })();
</script>
