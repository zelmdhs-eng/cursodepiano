---
/**
 * setup.astro
 *
 * Página pública de onboarding para novos usuários.
 * Instruções claras e amigáveis para fazer o deploy do CNX CMS em minutos.
 * Design voltado para usuários leigos, com botão Vercel em destaque.
 * URL: /setup — compartilhe com seus usuários.
 *
 * Proteção por senha: defina SETUP_PAGE_PASSWORD nas variáveis de ambiente
 * (Vercel ou .env) para exigir senha antes de exibir o conteúdo.
 */

import crypto from 'node:crypto';
import '../styles/global.css';
import '@fontsource/inter';
import '@fontsource/outfit';

const VERCEL_DEPLOY_URL = 'https://vercel.com/new/clone?repository-url=https%3A%2F%2Fgithub.com%2F8linksapp-maker%2Fcnx&env=ADMIN_SECRET,GITHUB_TOKEN,GITHUB_OWNER,GITHUB_REPO&envDescription=ADMIN_SECRET%3A%20sua%20senha%20(login%3A%20admin%40admin.com%20%2B%20este%20valor)%20%7C%20GITHUB_TOKEN%3A%20gere%20em%20github.com%2Fsettings%2Ftokens%20marcando%20%22repo%22%20%7C%20GITHUB_OWNER%3A%20seu%20usu%C3%A1rio%20do%20GitHub%20%7C%20GITHUB_REPO%3A%20nome%20do%20projeto%20escolhido%20acima&envLink=https%3A%2F%2Fgithub.com%2F8linksapp-maker%2Fcnx%23-vari%C3%A1veis-de-ambiente&project-name=meu-site-cnx&repository-name=meu-site-cnx';
const GITHUB_TOKEN_URL = 'https://github.com/settings/tokens/new?description=CNX+CMS&scopes=repo';

const SETUP_COOKIE = 'cnx_setup_access';
const SETUP_SALT = 'cnx_setup_v1';

function computeSetupToken(secret: string): string {
    return crypto.createHmac('sha256', secret).update(SETUP_SALT).digest('hex');
}

const setupPassword = process.env.SETUP_PAGE_PASSWORD?.trim() || '';
const cookieValue = Astro.cookies.get(SETUP_COOKIE)?.value || '';
const expectedToken = setupPassword ? computeSetupToken(setupPassword) : '';
const isAuthenticated = !setupPassword || (expectedToken && cookieValue === expectedToken);
---

<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>CNX CMS — Crie seu site em 5 minutos</title>
    <meta name="description" content="Guia simples para colocar seu site no ar com CNX CMS. Deploy grátis na Vercel em poucos cliques." />
</head>
<body class="min-h-screen font-sans antialiased text-slate-800 bg-gradient-to-b from-slate-50 via-white to-slate-50">
    <!-- Header -->
    <header class="border-b border-slate-200/80 bg-white/80 backdrop-blur-sm sticky top-0 z-10">
        <div class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-violet-500 to-fuchsia-500 flex items-center justify-center text-white font-bold text-lg shadow-lg shadow-violet-500/25">
                    CNX
                </div>
                <div>
                    <h1 class="font-heading font-bold text-slate-800 text-lg">CNX CMS</h1>
                    <p class="text-xs text-slate-500">Seu site profissional em minutos</p>
                </div>
            </div>
            <a href="/" class="text-sm font-medium text-violet-600 hover:text-violet-700 transition-colors">
                Ver site →
            </a>
        </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 py-10 pb-20">
        {!isAuthenticated ? (
            <!-- Formulário de senha -->
            <section class="max-w-md mx-auto mt-16">
                <div class="rounded-2xl bg-white border border-slate-200/80 p-8 shadow-lg">
                    <div class="text-center mb-6">
                        <div class="w-14 h-14 rounded-2xl bg-violet-100 flex items-center justify-center text-2xl mx-auto mb-4">🔐</div>
                        <h2 class="font-heading font-bold text-xl text-slate-800">Acesso restrito</h2>
                        <p class="text-slate-600 text-sm mt-1">Digite a senha para ver as instruções de setup</p>
                    </div>
                    <form id="setup-password-form" class="space-y-4">
                        <div>
                            <label for="setup-password" class="block text-sm font-medium text-slate-700 mb-1">Senha</label>
                            <input
                                type="password"
                                id="setup-password"
                                name="password"
                                required
                                autocomplete="current-password"
                                class="w-full px-4 py-3 rounded-xl border border-slate-300 focus:border-violet-500 focus:ring-2 focus:ring-violet-500/20 outline-none transition-all"
                                placeholder="Digite a senha"
                            />
                        </div>
                        <p id="setup-password-error" class="text-sm text-red-600 hidden"></p>
                        <button
                            type="submit"
                            class="w-full py-3 rounded-xl bg-violet-600 text-white font-semibold hover:bg-violet-700 transition-colors"
                        >
                            Entrar
                        </button>
                    </form>
                </div>
            </section>
            <script>
                (function() {
                    const form = document.getElementById('setup-password-form');
                    const input = document.getElementById('setup-password');
                    const errorEl = document.getElementById('setup-password-error');
                    if (form && input && errorEl) {
                        form.addEventListener('submit', async function(e) {
                            e.preventDefault();
                            errorEl.classList.add('hidden');
                            const password = input.value.trim();
                            if (!password) {
                                errorEl.textContent = 'Digite a senha';
                                errorEl.classList.remove('hidden');
                                return;
                            }
                            try {
                                const res = await fetch('/api/setup-auth', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ password }),
                                });
                                const data = await res.json();
                                if (data.success) {
                                    window.location.reload();
                                } else {
                                    errorEl.textContent = data.error || 'Senha incorreta';
                                    errorEl.classList.remove('hidden');
                                }
                            } catch (err) {
                                errorEl.textContent = 'Erro de conexão. Tente novamente.';
                                errorEl.classList.remove('hidden');
                            }
                        });
                    }
                })();
            </script>
        ) : (
            <>
        <!-- Hero -->
        <section class="text-center mb-12">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-50 text-emerald-700 text-sm font-medium mb-6 border border-emerald-200/60">
                <span>✨</span> Grátis · Sem banco de dados · 5 minutos
            </div>
            <h2 class="font-heading font-bold text-3xl sm:text-4xl text-slate-800 leading-tight mb-4">
                Crie seu site profissional<br />
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-600 to-fuchsia-600">em poucos cliques</span>
            </h2>
            <p class="text-lg text-slate-600 max-w-xl mx-auto leading-relaxed">
                Siga o passo a passo abaixo. Cada etapa leva menos de 2 minutos. No final, você terá um site no ar com painel para editar tudo.
            </p>
        </section>

        <!-- CTA Principal - Botão Vercel -->
        <section class="mb-16">
            <div class="rounded-2xl bg-gradient-to-br from-violet-500/10 via-fuchsia-500/5 to-transparent border border-violet-200/60 p-8 sm:p-10 text-center shadow-xl shadow-violet-500/5">
                <p class="text-sm font-semibold text-violet-600 uppercase tracking-wider mb-4">Comece aqui</p>
                <h3 class="font-heading font-bold text-xl sm:text-2xl text-slate-800 mb-2">Deploy em 1 clique</h3>
                <p class="text-slate-600 mb-6 max-w-md mx-auto">
                    Clique no botão abaixo para começar. Você vai precisar de uma conta no GitHub e na Vercel (ambas grátis).
                </p>
                <a
                    href={VERCEL_DEPLOY_URL}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block hover:opacity-90 transition-opacity"
                >
                    <img src="https://vercel.com/button" alt="Deploy with Vercel" class="h-12 w-auto" />
                </a>
                <p class="text-xs text-slate-500 mt-4">
                    ⚠️ Antes de clicar: faça o <strong>Passo 2</strong> abaixo (gerar token no GitHub).
                </p>
            </div>
        </section>

        <!-- Passos -->
        <section class="space-y-6">
            <h3 class="font-heading font-bold text-xl text-slate-800 mb-6 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-slate-200 flex items-center justify-center text-sm">📋</span>
                Passo a passo completo
            </h3>

            <!-- Passo 1 -->
            <article class="setup-card">
                <div class="setup-step">1</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">Criar duas contas gratuitas</h4>
                    <p class="text-slate-600 mb-4">Você vai precisar do <strong>GitHub</strong> (guarda o código) e da <strong>Vercel</strong> (publica o site). Ambos são grátis.</p>
                    <div class="flex flex-wrap gap-3">
                        <a href="https://github.com/signup" target="_blank" rel="noopener" class="setup-btn setup-btn-primary">
                            Criar conta no GitHub
                        </a>
                        <a href="https://vercel.com/signup" target="_blank" rel="noopener" class="setup-btn setup-btn-secondary">
                            Criar conta na Vercel
                        </a>
                    </div>
                    <p class="text-sm text-slate-500 mt-3">💡 Na Vercel, use <strong>Continue with GitHub</strong> para conectar as contas.</p>
                </div>
            </article>

            <!-- Passo 2 -->
            <article class="setup-card">
                <div class="setup-step">2</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">Gerar um token no GitHub</h4>
                    <p class="text-slate-600 mb-4">Esse token permite que o sistema salve suas alterações. <strong>Faça isso antes de clicar no botão Deploy.</strong></p>
                    <a href={GITHUB_TOKEN_URL} target="_blank" rel="noopener" class="setup-btn setup-btn-primary inline-flex items-center gap-2">
                        Abrir página do token
                    </a>
                    <ol class="list-decimal list-inside text-slate-600 text-sm mt-4 space-y-2">
                        <li>O campo "Note" pode ficar como está</li>
                        <li>Role até o final e clique em <strong>Generate token</strong></li>
                        <li><strong>Copie o token</strong> (começa com ghp_...) — você só verá uma vez!</li>
                        <li>Guarde em um bloco de notas para colar no próximo passo</li>
                    </ol>
                </div>
            </article>

            <!-- Passo 3 -->
            <article class="setup-card">
                <div class="setup-step">3</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">Clicar no botão Deploy e preencher</h4>
                    <p class="text-slate-600 mb-4">Volte ao topo desta página e clique no botão <strong>Deploy with Vercel</strong>. Depois preencha:</p>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm border-collapse">
                            <thead>
                                <tr class="border-b border-slate-200">
                                    <th class="text-left py-2 pr-4 font-semibold text-slate-700">O que preencher</th>
                                    <th class="text-left py-2 font-semibold text-slate-700">Exemplo</th>
                                </tr>
                            </thead>
                            <tbody class="text-slate-600">
                                <tr class="border-b border-slate-100"><td class="py-2 pr-4"><code class="text-violet-600">ADMIN_SECRET</code></td><td>Sua senha (ex: minhasenha2025)</td></tr>
                                <tr class="border-b border-slate-100"><td class="py-2 pr-4"><code class="text-violet-600">GITHUB_TOKEN</code></td><td>O token que você copiou</td></tr>
                                <tr class="border-b border-slate-100"><td class="py-2 pr-4"><code class="text-violet-600">GITHUB_OWNER</code></td><td>Seu usuário do GitHub</td></tr>
                                <tr><td class="py-2 pr-4"><code class="text-violet-600">GITHUB_REPO</code></td><td>O mesmo nome do projeto (ex: meu-site-cnx)</td></tr>
                            </tbody>
                        </table>
                    </div>
                    <p class="text-sm text-slate-500 mt-3">⏱️ Aguarde ~2 minutos. Quando terminar, seu site estará no ar!</p>
                </div>
            </article>

            <!-- Passo 4 -->
            <article class="setup-card">
                <div class="setup-step">4</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">Acessar o painel</h4>
                    <p class="text-slate-600 mb-2">Abra no navegador: <code class="bg-slate-100 px-2 py-0.5 rounded text-sm">https://SEU-PROJETO.vercel.app/admin</code></p>
                    <p class="text-slate-600 mb-2">(Troque <strong>SEU-PROJETO</strong> pelo nome que você deu no deploy)</p>
                    <p class="text-slate-600">Na primeira vez: crie sua conta. Depois: use <strong>admin@admin.com</strong> e a senha que você colocou em ADMIN_SECRET.</p>
                </div>
            </article>

            <!-- Passo 5 -->
            <article class="setup-card">
                <div class="setup-step">5</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">Trocar e-mail e senha (segurança)</h4>
                    <p class="text-slate-600 mb-2">Logo após o primeiro acesso, vá em <strong>Autores</strong> → clique no Administrador → altere e-mail, senha e nome para os seus.</p>
                </div>
            </article>

            <!-- Passo 6 -->
            <article class="setup-card setup-card-important">
                <div class="setup-step setup-step-important">6</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">⚠️ Ativar atualizações (obrigatório)</h4>
                    <p class="text-slate-600 mb-4">Sem isso, o botão "Aplicar agora" não funciona. No GitHub do seu projeto:</p>
                    <ol class="list-decimal list-inside text-slate-600 text-sm space-y-1">
                        <li><strong>Settings</strong> → <strong>Actions</strong> → <strong>General</strong></li>
                        <li>Em "Workflow permissions": marque <strong>Read and write permissions</strong></li>
                        <li>Marque também <strong>Allow GitHub Actions to create and approve pull requests</strong></li>
                        <li>Clique em <strong>Save</strong></li>
                    </ol>
                </div>
            </article>

            <!-- Passo 7 -->
            <article class="setup-card">
                <div class="setup-step">7</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">Personalizar seu site</h4>
                    <p class="text-slate-600 mb-2">No painel: edite <strong>Páginas</strong> (Home, Menu, Rodapé), crie posts em <strong>Posts</strong>, adicione categorias. Tudo de forma visual!</p>
                </div>
            </article>
        </section>

        <!-- Resumo final -->
        <section class="mt-16 rounded-2xl bg-slate-100/80 border border-slate-200/60 p-6 sm:p-8">
            <h3 class="font-heading font-bold text-lg text-slate-800 mb-4">🎉 Pronto!</h3>
            <p class="text-slate-600 mb-4">
                Seu site está no ar. Acesse o painel sempre em <strong>/admin</strong> para editar. Quando houver atualizações do template, um banner amarelo aparecerá — clique em "Aplicar agora" para receber as melhorias.
            </p>
            <p class="text-sm text-slate-500">
                Dúvidas? No painel, vá em <strong>Ajuda</strong> para o guia completo.
            </p>
        </section>
        </>
        )}
    </main>

    <footer class="border-t border-slate-200 bg-white/50 py-6 mt-12">
        <div class="max-w-3xl mx-auto px-4 text-center text-sm text-slate-500">
            CNX CMS — MIT · Use, modifique e distribua livremente
        </div>
    </footer>
</body>
</html>

<style>
    .font-heading {
        font-family: 'Outfit', system-ui, sans-serif;
    }
    .setup-card {
        @apply rounded-2xl bg-white border border-slate-200/80 p-6 sm:p-8 shadow-sm hover:shadow-md transition-shadow;
    }
    .setup-card-important {
        @apply border-amber-200 bg-amber-50/30;
    }
    .setup-step {
        @apply w-10 h-10 rounded-xl bg-violet-100 text-violet-600 font-bold flex items-center justify-center text-lg mb-4;
    }
    .setup-step-important {
        @apply bg-amber-100 text-amber-700;
    }
    .setup-btn {
        @apply inline-flex items-center justify-center px-5 py-2.5 rounded-xl font-semibold text-sm transition-all;
    }
    .setup-btn-primary {
        @apply bg-violet-600 text-white hover:bg-violet-700 shadow-md shadow-violet-500/20;
    }
    .setup-btn-secondary {
        @apply bg-white border border-slate-300 text-slate-700 hover:bg-slate-50;
    }
</style>
