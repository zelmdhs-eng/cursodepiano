---
/**
 * sobre.astro - Página Sobre Nós
 * 
 * Página institucional sobre a empresa seguindo o mesmo padrão de design da home.
 * Estrutura: Hero, Missão/Visão, Valores, Equipe, CTA
 */

import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import { readSingleton } from '../utils/singleton-utils';
import paulaPhoto from '../assets/images/paula.jpg';

// Obter tema ativo
const settings = await getEntry('siteSettings', 'settings');
const activeThemeId = settings?.data.activeTheme || 'classic';

const data = await readSingleton('about', activeThemeId);
---

<MainLayout title={`${data?.heroTitle || 'Sobre Nós'} - Curso de Piano`}>
    
    <!-- HERO SECTION -->
    <section class="relative min-h-[70vh] flex items-center justify-center pt-24 md:pt-32 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-black via-black to-[#0a0a0a]">
            <div class="absolute inset-0 opacity-30">
                <div class="absolute inset-0" style="background-image: linear-gradient(to right, rgba(168, 85, 247, 0.1) 1px, transparent 1px), linear-gradient(to bottom, rgba(168, 85, 247, 0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
            </div>
            <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px] animate-pulse"></div>
            <div class="absolute bottom-1/3 right-1/4 w-[400px] h-[400px] bg-secondary/8 rounded-full blur-[100px] animate-pulse" style="animation-delay: 1.5s;"></div>
        </div>
        
        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-5xl mx-auto text-center">
                <div class="inline-flex items-center gap-2 px-5 py-2.5 mb-10 rounded-full border border-primary/40 bg-primary/10 backdrop-blur-sm">
                    <span class="text-sm md:text-base font-semibold text-primary tracking-wide">Sobre Nós</span>
                </div>
                
                <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-black text-white leading-[1.1] mb-8">
                    {data?.heroTitle || 'Quem Somos'}
                </h1>
                
                {data?.heroSubtitle && (
                    <p class="text-lg md:text-xl lg:text-2xl text-slate-400 max-w-3xl mx-auto mb-12 leading-relaxed">
                        {data.heroSubtitle}
                    </p>
                )}
            </div>
        </div>
        
        <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-black via-black/80 to-transparent"></div>
    </section>

    <!-- MISSÃO E VISÃO -->
    <section class="py-20 md:py-32 bg-black relative overflow-hidden">
        <div class="container mx-auto px-6">
            <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
                <!-- Missão -->
                <div class="relative p-8 md:p-10 rounded-2xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all group">
                    <div class="w-16 h-16 rounded-xl bg-primary/20 flex items-center justify-center mb-6">
                        <span class="text-4xl">🎯</span>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-6">{data?.missionTitle || 'Nossa Missão'}</h3>
                    <p class="text-slate-400 text-lg leading-relaxed">
                        {data?.missionDescription || 'Criar soluções web modernas que realmente funcionam e geram resultados.'}
                    </p>
                    <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                </div>
                
                <!-- Visão -->
                <div class="relative p-8 md:p-10 rounded-2xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all group">
                    <div class="w-16 h-16 rounded-xl bg-secondary/20 flex items-center justify-center mb-6">
                        <span class="text-4xl">🔮</span>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-6">{data?.visionTitle || 'Nossa Visão'}</h3>
                    <p class="text-slate-400 text-lg leading-relaxed">
                        {data?.visionDescription || 'Ser referência em desenvolvimento web moderno com JAMstack.'}
                    </p>
                    <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-secondary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- VALORES -->
    {data?.values && data.values.length > 0 && (
        <section class="py-20 md:py-32 bg-[#0a0a0a] relative overflow-hidden">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary/3 rounded-full blur-[150px] pointer-events-none"></div>
            
            <div class="container mx-auto px-6 relative z-10">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-black text-white mb-4">
                        {data?.valuesTitle || 'Nossos Valores'}
                    </h2>
                </div>
                
                <div class="grid md:grid-cols-3 gap-6 lg:gap-8 max-w-6xl mx-auto">
                    {data.values.map((value: any) => (
                        <div class="relative p-8 rounded-2xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all group hover:-translate-y-2">
                            <div class="w-14 h-14 rounded-xl bg-primary/20 flex items-center justify-center mb-6">
                                <span class="text-3xl">{value.icon || '💎'}</span>
                            </div>
                            <h3 class="text-xl font-bold text-white mb-4">{value.title}</h3>
                            <p class="text-slate-400 leading-relaxed">
                                {value.description}
                            </p>
                            <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
                        </div>
                    ))}
                </div>
            </div>
        </section>
    )}

    <!-- EQUIPE -->
    {data?.teamMembers && data.teamMembers.length > 0 && (
        <section class="py-20 md:py-32 bg-black relative overflow-hidden">
            <div class="container mx-auto px-6">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-black text-white mb-4">
                        {data?.teamTitle || 'Nossa Equipe'}
                    </h2>
                </div>
                
                <div class={`mx-auto ${data.teamMembers.length === 1 ? 'max-w-3xl' : 'grid md:grid-cols-2 gap-8 max-w-5xl'}`}>
                    {data.teamMembers.map((member: any) => (
                        <div class={`flex flex-col md:flex-row gap-8 items-center md:items-start p-8 md:p-10 rounded-3xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all group ${data.teamMembers.length === 1 ? 'text-center md:text-left' : ''}`}>
                            {member.photo ? (
                                <div class="w-32 h-32 md:w-40 md:h-40 rounded-full overflow-hidden border-4 border-primary/30 shadow-2xl flex-shrink-0 group-hover:border-primary/60 transition-colors">
                                    <Image 
                                        src={member.name === 'Paula Franco' ? paulaPhoto : member.photo} 
                                        alt={member.name}
                                        width={400}
                                        height={400}
                                        class="w-full h-full object-cover"
                                        loading="lazy"
                                    />
                                </div>
                            ) : (
                                <div class="w-32 h-32 md:w-40 md:h-40 rounded-full bg-primary/20 border-4 border-primary/30 shadow-2xl flex-shrink-0 flex items-center justify-center text-5xl font-bold text-primary">
                                    {member.name.charAt(0)}
                                </div>
                            )}
                            <div class="flex-1 flex flex-col justify-center h-full">
                                <h3 class="text-3xl font-bold text-white mb-2">{member.name}</h3>
                                <p class="text-lg text-primary mb-4 font-semibold tracking-wide">{member.role}</p>
                                <p class="text-slate-300 text-lg leading-relaxed">{member.bio}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>
    )}

    <!-- CERTIFICADO -->
    <section class="py-20 md:py-24 bg-[#050505] relative border-t border-white/5">
        <div class="container mx-auto px-6">
            <div class="max-w-4xl mx-auto bg-gradient-to-r from-primary/10 to-transparent p-[1px] rounded-3xl overflow-hidden">
                <div class="bg-black p-8 md:p-12 rounded-3xl flex flex-col md:flex-row items-center gap-8 md:gap-12 relative overflow-hidden">
                    <div class="absolute -right-20 -top-20 w-64 h-64 bg-primary/10 rounded-full blur-[80px] pointer-events-none"></div>
                    
                    <div class="w-24 h-24 md:w-32 md:h-32 rounded-2xl bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center flex-shrink-0 shadow-[0_0_30px_rgba(124,58,237,0.15)] border border-primary/20">
                        <span class="text-5xl md:text-6xl">🎓</span>
                    </div>
                    
                    <div class="flex-1 text-center md:text-left relative z-10">
                        <h3 class="text-2xl md:text-3xl font-bold text-white mb-3">Certificação Profissional</h3>
                        <p class="text-slate-400 text-lg mb-6 leading-relaxed">
                            Acesse minha certificação oficial de formação na área, garantindo a sólida base teórica e técnica aplicada aos meus alunos e clientes.
                        </p>
                        
                        <a 
                            href="/certificado-paula.pdf" 
                            target="_blank"
                            class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-xl border border-white/10 transition-colors"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                            Visualizar Certificado em PDF
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA BANNER -->
    {data && data.ctaTitle && (
        <section class="py-20 md:py-32 bg-[#0a0a0a] relative overflow-hidden">
            <div class="container mx-auto px-6">
                <div class="max-w-4xl mx-auto text-center">
                    <div class="p-12 rounded-3xl bg-gradient-to-br from-primary/20 to-secondary/20 border-2 border-primary/50 relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-r from-black/20 to-transparent"></div>
                        <div class="relative z-10">
                            <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-black text-white mb-6">
                                {data.ctaTitle}
                            </h2>
                            {data.ctaDescription && (
                                <p class="text-white/80 text-lg md:text-xl mb-10 leading-relaxed">
                                    {data.ctaDescription}
                                </p>
                            )}
                            {data.ctaButtonText && data.ctaButtonUrl && (
                                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                                    <a 
                                        href={data.ctaButtonUrl} 
                                        class="inline-flex items-center justify-center gap-2 px-10 py-5 bg-white text-primary font-bold rounded-2xl hover:scale-105 transition-transform shadow-2xl"
                                    >
                                        {data.ctaButtonText}
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M5 12h14"></path>
                                            <path d="m12 5 7 7-7 7"></path>
                                        </svg>
                                    </a>
                                </div>
                            )}
                        </div>
                    </div>
                </div>
            </div>
        </section>
    )}

</MainLayout>
