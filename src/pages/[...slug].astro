---
/**
 * [...slug].astro
 *
 * Rota para posts na raiz do site (quando blogUrlPrefix = 'root').
 * URLs: /slug-do-post | /2025/03/slug | /2025/03/04/slug
 * Só gera paths quando blogUrlPrefix está em 'root'.
 */

import { getCollection, getEntry, render } from 'astro:content';
import BlogPost from '../themes/classic/BlogPost.astro';
import { readPost } from '../utils/post-utils';
import { buildPostPath, type BlogPermalinkStructure } from '../utils/blog-permalink';

export const prerender = true;

export async function getStaticPaths() {
  const settings = await getEntry('siteSettings', 'settings').catch(() => null);
  const prefix = (settings?.data?.blogUrlPrefix as string) || 'blog';

  if (prefix !== 'root') return [];

  const posts = await getCollection('posts');
  const structure = (settings?.data?.blogPermalinkStructure as BlogPermalinkStructure) || 'postname';

  return posts.map(post => ({
    params: { slug: buildPostPath({ ...post, data: { ...post.data, slug: post.data.slug || post.id } }, structure) },
    props: { post },
  }));
}

const { slug } = Astro.params;
const { post } = Astro.props;

if (!post) return Astro.redirect('/404');

const { Content } = await render(post);
const author = post.data.author ? await getEntry('authors', post.data.author) : null;

const postFile = await readPost(post.data.slug);
const wordCount = postFile?.content ? postFile.content.replace(/<[^>]+>/g, ' ').split(/\s+/).filter(Boolean).length : 0;
const readingTimeMinutes = Math.max(1, Math.ceil(wordCount / 200));

const settings = await getEntry('siteSettings', 'settings').catch(() => null);
const siteMode = settings?.data?.siteMode || 'blog';
const layoutType = siteMode === 'local' ? 'local' : 'main';
---

<BlogPost
    post={post}
    author={author}
    Content={Content}
    themeId="classic"
    layoutType={layoutType}
    readingTimeMinutes={readingTimeMinutes}
/>
