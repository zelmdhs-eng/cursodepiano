---
/**
 * [location]/index.astro
 *
 * Página do bairro/cidade — lista os serviços disponíveis naquela localidade.
 * Corrige o bug do breadcrumb: ao clicar no bairro, em vez de 404, exibe esta página.
 * URL: /{bairro-slug} — ex: /copacabana
 */

import LocalLayout from '../../layouts/LocalLayout.astro';
import { readLocation } from '../../utils/location-utils';
import { listServices } from '../../utils/service-utils';
import { readSingleton } from '../../utils/singleton-utils';

const { location: locationSlug } = Astro.params;
const locationFile = await readLocation(locationSlug as string);

if (!locationFile) {
    return Astro.redirect('/404', 404);
}

const location = locationFile.data;
if (!location.active) {
    return Astro.redirect('/404', 404);
}

const services = await listServices();
const activeServices = services.filter(({ data }) => data.active !== false);
const localData = await readSingleton('home', 'local');
const company = localData?.companyName || 'Minha Empresa';
---

<LocalLayout
    title={`${location.name} — ${company}`}
    description={`Serviços de ${company} em ${location.name}${location.city ? `, ${location.city}` : ''}. Solicite orçamento.`}
>

    <!-- Breadcrumb -->
    <nav style="padding: 0.85rem 1.5rem; background: #fff; border-bottom: 1px solid #e2e8f0; font-size: 0.82rem; color: #334155;">
        <div class="container mx-auto">
            <a href="/" style="color: var(--page-accent, #2563eb); text-decoration: none; font-weight: 600;">Início</a>
            <span style="margin: 0 0.4rem; color: #94a3b8;">›</span>
            <span style="color: #334155; font-weight: 500;">{location.name}</span>
        </div>
    </nav>

    <!-- Hero -->
    <section style="background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%); padding: 3rem 1.5rem; text-align: center;">
        <div class="container mx-auto">
            <p style="font-size: 0.9rem; color: #94a3b8; margin-bottom: 0.5rem;">📍 {location.name}{location.city && location.city !== location.name ? ` · ${location.city}` : ''} — {location.state}</p>
            <h1 style="font-size: clamp(1.5rem, 4vw, 2.25rem); font-weight: 800; color: #fff; font-family: 'Outfit', sans-serif;">
                Nossos Serviços em {location.name}
            </h1>
            <p style="color: #94a3b8; font-size: 1rem; max-width: 560px; margin: 0.5rem auto 0;">
                Escolha o serviço que você precisa e solicite um orçamento gratuito
            </p>
        </div>
    </section>

    <!-- Lista de serviços -->
    <section style="padding: 3rem 1.5rem; background: #f8fafc;">
        <div class="container mx-auto">
            {activeServices.length > 0 ? (
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; max-width: 900px; margin: 0 auto;">
                    {activeServices.map(({ data: service }) => (
                        <a
                            href={`/${location.slug}/${service.slug}`}
                            style="display: flex; flex-direction: column; gap: 0.6rem; padding: 1.25rem 1.5rem; border-radius: 12px; border: 2px solid #e2e8f0; background: #fff; text-decoration: none; transition: all 0.2s;"
                        >
                            {service.icon && <span style="font-size: 1.75rem;">{service.icon}</span>}
                            <h2 style="font-size: 1.05rem; font-weight: 700; color: #0f172a; font-family: 'Outfit', sans-serif;">
                                {service.title}
                            </h2>
                            {service.shortDescription && (
                                <p style="font-size: 0.875rem; color: #64748b; line-height: 1.5;">
                                    {service.shortDescription}
                                </p>
                            )}
                            <span style="font-size: 0.8rem; font-weight: 700; color: #2563eb;">
                                Ver detalhes →
                            </span>
                        </a>
                    ))}
                </div>
            ) : (
                <div style="text-align: center; padding: 3rem 1rem; color: #64748b;">
                    <p style="font-size: 1rem;">Nenhum serviço cadastrado ainda.</p>
                    <p style="font-size: 0.875rem; margin-top: 0.25rem;">Adicione serviços no painel administrativo.</p>
                    <a href="/" style="display: inline-block; margin-top: 1rem; padding: 0.5rem 1rem; border-radius: 8px; background: #2563eb; color: #fff; text-decoration: none; font-size: 0.9rem; font-weight: 600;">← Voltar ao início</a>
                </div>
            )}
        </div>
    </section>

</LocalLayout>
