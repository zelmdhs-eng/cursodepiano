---
import { readSingleton } from '../utils/singleton-utils';
import Lp1Template from '../themes/classic/Lp1.astro';

// Inicializando os dados do template de Alta Conversão focado no curso de piano
const lp1 = await readSingleton('lp1', 'classic') || {};
---

<Lp1Template 
    lp1Data={lp1}
    themeId="classic"
/>
