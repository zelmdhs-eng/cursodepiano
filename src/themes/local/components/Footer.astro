---
/**
 * Footer.astro — Tema Local (Modo Local / Rank and Rent)
 *
 * Rodapé com 3 colunas para sites de negócio local:
 *   Coluna 1 — Empresa (nome, descrição, redes sociais)
 *   Coluna 2 — Serviços (lista dos serviços em destaque)
 *   Coluna 3 — NAP (Name, Address, Phone — crítico para SEO local)
 *
 * Lê dados do singleton 'local/home.yaml' via readSingleton.
 */

import { readSingleton } from '../../../utils/singleton-utils';
import { getSiteContactInfo, formatPhone } from '../../../utils/site-contact';
import { listServices } from '../../../utils/service-utils';
import { getPrincipalLocationSlug } from '../../../utils/location-utils';

const localData   = await readSingleton('home', 'local');
const contact     = await getSiteContactInfo();
const allServices = await listServices();
const principalSlug = await getPrincipalLocationSlug();
const featuredSlugs: string[] = (localData?.featuredServices || []).slice(0, 6);
const featuredServices = featuredSlugs.length > 0
    ? featuredSlugs.map(slug => allServices.find(s => s.data.slug === slug)?.data).filter(Boolean)
    : allServices.slice(0, 6).map(s => s.data);
const serviceBase = principalSlug ? `/${principalSlug}` : '/servicos';

const year        = new Date().getFullYear();
const company     = localData?.companyName    || 'Minha Empresa';
const phone       = contact.phone;
const whatsapp    = contact.whatsapp;
const email       = localData?.companyEmail   || '';
const address     = localData?.companyAddress || '';
const city        = localData?.companyCity    || '';
const state       = localData?.companyState   || '';
const cep         = localData?.companyCEP     || '';
const aboutText   = localData?.aboutText      || 'Profissionais especializados com anos de experiência. Qualidade e confiança em cada serviço.';

const waMsg = encodeURIComponent(localData?.heroWhatsappMessage || 'Olá! Vim pelo site e gostaria de um orçamento.');
const waUrl = whatsapp ? `https://wa.me/55${whatsapp}?text=${waMsg}` : '#';
const phoneFormatted = formatPhone(phone);
---

<footer class="local-footer">
    <div class="local-footer-inner">
        <div class="local-footer-grid">

            <!-- Coluna 1: Empresa -->
            <div class="local-footer-col">
                <h3 class="local-footer-title">{company}</h3>
                <p class="local-footer-desc">
                    {aboutText}
                </p>
                {whatsapp && (
                    <a href={waUrl} target="_blank" rel="noopener noreferrer" class="local-footer-wa">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        WhatsApp
                    </a>
                )}
            </div>

            <!-- Coluna 2: Serviços -->
            <div class="local-footer-col">
                <h3 class="local-footer-title">Serviços</h3>
                <ul class="local-footer-services">
                    {featuredServices.slice(0, 6).map((service: any) => service && (
                        <li>
                            <a href={`${serviceBase}/${service.slug}`} class="local-footer-link">
                                <span class="local-footer-arrow">→</span>
                                {service.title}
                            </a>
                        </li>
                    ))}
                    <li>
                        <a href="/servicos" class="local-footer-link local-footer-link-all">Ver todos os serviços →</a>
                    </li>
                </ul>
            </div>

            <!-- Coluna 3: NAP -->
            <div class="local-footer-col">
                <h3 class="local-footer-title">Contato</h3>
                <ul class="local-footer-contact">
                    {(address || city) && (
                        <li class="local-footer-contact-item">
                            <span class="local-footer-icon">📍</span>
                            <address class="local-footer-address">
                                {address && <span class="block">{address}</span>}
                                {(city || state) && <span class="block">{city}{city && state ? '/' : ''}{state}</span>}
                                {cep && <span class="block">CEP: {cep}</span>}
                            </address>
                        </li>
                    )}
                    {phone && (
                        <li class="local-footer-contact-item">
                            <span class="local-footer-icon">📞</span>
                            <a href={`tel:+55${phone}`} class="local-footer-contact-link">{phoneFormatted}</a>
                        </li>
                    )}
                    {whatsapp && (
                        <li class="local-footer-contact-item">
                            <span class="local-footer-icon">💬</span>
                            <a href={waUrl} target="_blank" class="local-footer-contact-link">WhatsApp: {formatPhone(whatsapp)}</a>
                        </li>
                    )}
                    {email && (
                        <li class="local-footer-contact-item">
                            <span class="local-footer-icon">✉️</span>
                            <a href={`mailto:${email}`} class="local-footer-contact-link">{email}</a>
                        </li>
                    )}
                </ul>
            </div>

        </div>

        <div class="local-footer-copy">
            © {year} {company}. Todos os direitos reservados.
        </div>
    </div>
</footer>

<style>
    .local-footer {
        background: #0c1222;
        border-top: 2px solid #1e40af;
    }
    .local-footer-inner {
        max-width: 72rem;
        margin: 0 auto;
        padding: 3rem 1.5rem 2rem;
    }
    .local-footer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
        margin-bottom: 2.5rem;
    }
    @media (min-width: 768px) {
        .local-footer-grid { grid-template-columns: repeat(3, 1fr); gap: 3rem; }
    }
    .local-footer-title {
        font-size: 0.875rem;
        font-weight: 700;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 1rem;
        font-family: 'Outfit', sans-serif;
    }
    .local-footer-desc {
        font-size: 0.9rem;
        line-height: 1.7;
        color: #cbd5e1;
        margin-bottom: 1.25rem;
    }
    .local-footer-wa {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.25rem;
        border-radius: 999px;
        background: #25d366;
        color: #fff;
        font-size: 0.875rem;
        font-weight: 700;
        text-decoration: none;
        transition: opacity 0.15s;
    }
    .local-footer-wa:hover { opacity: 0.9; }
    .local-footer-services { list-style: none; padding: 0; margin: 0; }
    .local-footer-services li { margin-bottom: 0.6rem; }
    .local-footer-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.9rem;
        color: #cbd5e1;
        text-decoration: none;
        transition: color 0.15s;
    }
    .local-footer-link:hover { color: #fff; }
    .local-footer-arrow { color: #60a5fa; font-weight: 700; }
    .local-footer-link-all { color: #60a5fa; font-weight: 600; }
    .local-footer-link-all:hover { color: #93c5fd; }
    .local-footer-contact { list-style: none; padding: 0; margin: 0; }
    .local-footer-contact-item {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 0.85rem;
    }
    .local-footer-icon { font-size: 1rem; flex-shrink: 0; }
    .local-footer-address { font-style: normal; line-height: 1.6; color: #cbd5e1; }
    .local-footer-contact-link {
        color: #cbd5e1;
        text-decoration: none;
        transition: color 0.15s;
    }
    .local-footer-contact-link:hover { color: #fff; }
    .local-footer-copy {
        padding-top: 1.5rem;
        border-top: 1px solid #1e293b;
        text-align: center;
        font-size: 0.8rem;
        color: #94a3b8;
    }
</style>
