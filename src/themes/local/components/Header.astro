---
/**
 * Header.astro — Tema Local (Modo Local / Rank and Rent)
 *
 * Cabeçalho para sites de negócio local.
 * Menu: Home, Serviços (dropdown com 6 destacados), Quem Somos, Contato, Blog.
 * Lê featuredServices do local/home para Home, Footer e menu Serviços.
 */

import { readSingleton } from '../../../utils/singleton-utils';
import { getSiteContactInfo, formatPhone } from '../../../utils/site-contact';
import { listServices } from '../../../utils/service-utils';
import { getPrincipalLocationSlug } from '../../../utils/location-utils';

const menuData    = await readSingleton('menu', 'classic');
const localData   = await readSingleton('home', 'local');
const contact     = await getSiteContactInfo();
const allServices = await listServices();
const principalSlug = await getPrincipalLocationSlug();

const logoType  = menuData?.logoType  || 'text';
const logoText  = menuData?.logoText  || 'Minha Empresa';
const logoImage = menuData?.logoImage || '';
const phone     = contact.phone;
const whatsapp  = contact.whatsapp;
const waMessage = encodeURIComponent(localData?.heroWhatsappMessage || 'Olá! Vim pelo site e gostaria de um orçamento.');
const waUrl     = whatsapp ? `https://wa.me/55${whatsapp}?text=${waMessage}` : '#';
const phoneFormatted = formatPhone(phone);

const featuredSlugs: string[] = (localData?.featuredServices || []).slice(0, 6);
const featuredServicesForNav = featuredSlugs.length > 0
    ? featuredSlugs.map(s => allServices.find(svc => svc.data.slug === s)?.data).filter(Boolean)
    : [];
const serviceBase = principalSlug ? `/${principalSlug}` : '/servicos';
---

<header class="sticky top-0 z-50 shadow-sm" style="background: #fff; border-bottom: 2px solid #1d4ed8;">
    <div class="container mx-auto px-4 h-16 flex items-center justify-between gap-4">
        <!-- Logo -->
        <a href="/" class="flex items-center hover:opacity-80 transition-opacity flex-shrink-0">
            {logoType === 'image' && logoImage ? (
                <img src={logoImage} alt={logoText || 'Logo'} class="h-10 w-auto object-contain" loading="eager" />
            ) : (
                <span class="text-xl font-heading font-black tracking-tight" style="color: var(--local-text);">
                    {logoText}
                </span>
            )}
        </a>

        <!-- Menu de navegação (desktop) -->
        <nav class="hidden md:flex items-center gap-1" aria-label="Navegação principal">
            <a href="/" class="px-3 py-2 rounded-lg text-sm font-semibold transition-colors hover:bg-slate-100" style="color: var(--local-text);">Home</a>
            {featuredServicesForNav.length > 0 ? (
                <details class="relative group">
                    <summary class="list-none cursor-pointer px-3 py-2 rounded-lg text-sm font-semibold hover:bg-slate-100 flex items-center gap-0.5" style="color: var(--local-text);">
                        Serviços
                        <span class="text-xs opacity-70" style="transform: rotate(90deg);">▶</span>
                    </summary>
                    <div class="absolute top-full left-0 mt-0.5 py-2 min-w-[200px] bg-white rounded-lg shadow-lg border border-slate-200 z-50">
                        {featuredServicesForNav.map((svc: any) => (
                            <a href={`${serviceBase}/${svc.slug}`} class="block px-4 py-2.5 text-sm font-medium hover:bg-slate-50 rounded-none first:rounded-t-lg last:rounded-b-lg" style="color: var(--local-text);">{svc.title}</a>
                        ))}
                        <a href="/servicos" class="block px-4 py-2.5 text-sm font-semibold border-t border-slate-100 hover:bg-slate-50" style="color: #2563eb;">Ver todos →</a>
                    </div>
                </details>
            ) : (
                <a href="/servicos" class="px-3 py-2 rounded-lg text-sm font-semibold transition-colors hover:bg-slate-100" style="color: var(--local-text);">Serviços</a>
            )}
            <a href="/sobre" class="px-3 py-2 rounded-lg text-sm font-semibold transition-colors hover:bg-slate-100" style="color: var(--local-text);">Quem Somos</a>
            <a href="/contato" class="px-3 py-2 rounded-lg text-sm font-semibold transition-colors hover:bg-slate-100" style="color: var(--local-text);">Contato</a>
            <a href="/blog" class="px-3 py-2 rounded-lg text-sm font-semibold transition-colors hover:bg-slate-100" style="color: var(--local-text);">Blog</a>
        </nav>

        <!-- Menu mobile (hamburger) -->
        <details class="md:hidden relative" id="nav-mobile">
            <summary class="list-none cursor-pointer p-2 -mr-2 rounded-lg hover:bg-slate-100" aria-label="Abrir menu">
                <svg class="w-6 h-6" style="color: var(--local-text);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </summary>
            <div class="absolute top-full right-0 mt-1 py-2 px-3 min-w-[220px] bg-white rounded-lg shadow-lg border border-slate-200 flex flex-col gap-0.5 z-50">
                <a href="/" class="block px-3 py-2.5 rounded-lg text-sm font-semibold hover:bg-slate-100" style="color: var(--local-text);" onclick="document.getElementById('nav-mobile')?.removeAttribute('open')">Home</a>
                {featuredServicesForNav.length > 0 ? (
                    <>
                        <div class="px-3 py-1.5 text-xs font-bold uppercase tracking-wider text-slate-400">Serviços</div>
                        {featuredServicesForNav.map((svc: any) => (
                            <a href={`${serviceBase}/${svc.slug}`} class="block px-3 py-2 rounded-lg text-sm font-medium hover:bg-slate-100" style="color: var(--local-text); padding-left: 1.25rem;" onclick="document.getElementById('nav-mobile')?.removeAttribute('open')">{svc.title}</a>
                        ))}
                        <a href="/servicos" class="block px-3 py-2 rounded-lg text-sm font-semibold text-blue-600 hover:bg-slate-100" onclick="document.getElementById('nav-mobile')?.removeAttribute('open')">Ver todos →</a>
                    </>
                ) : (
                    <a href="/servicos" class="block px-3 py-2.5 rounded-lg text-sm font-semibold hover:bg-slate-100" style="color: var(--local-text);" onclick="document.getElementById('nav-mobile')?.removeAttribute('open')">Serviços</a>
                )}
                <a href="/sobre" class="block px-3 py-2.5 rounded-lg text-sm font-semibold hover:bg-slate-100" style="color: var(--local-text);" onclick="document.getElementById('nav-mobile')?.removeAttribute('open')">Quem Somos</a>
                <a href="/contato" class="block px-3 py-2.5 rounded-lg text-sm font-semibold hover:bg-slate-100" style="color: var(--local-text);" onclick="document.getElementById('nav-mobile')?.removeAttribute('open')">Contato</a>
                <a href="/blog" class="block px-3 py-2.5 rounded-lg text-sm font-semibold hover:bg-slate-100" style="color: var(--local-text);" onclick="document.getElementById('nav-mobile')?.removeAttribute('open')">Blog</a>
            </div>
        </details>

        <!-- Phone (desktop) -->
        {phone && (
            <a
                href={`tel:+55${phone.replace(/\D/g,'')}`}
                class="hidden md:flex items-center gap-2 font-bold text-lg"
                style="color: var(--local-text);"
            >
                <span class="text-2xl">📞</span>
                <span>{phoneFormatted}</span>
            </a>
        )}

        <!-- WhatsApp CTA -->
        {whatsapp && (
            <a
                href={waUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-4 py-2.5 rounded-full font-bold text-sm text-white transition-all hover:opacity-90 hover:scale-105 flex-shrink-0"
                style="background: #25d366;"
            >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                <span class="hidden sm:inline">Chamar no WhatsApp</span>
                <span class="sm:hidden">WhatsApp</span>
            </a>
        )}
    </div>
</header>
