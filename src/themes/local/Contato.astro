---
/**
 * Contato.astro — Tema Local (Modo Local / Rank and Rent)
 *
 * Página de contato completa para sites de negócio local.
 * Usa identidade visual do tema local: hero azul, seções alternadas #f8fafc/#fff,
 * cards brancos com borda #e2e8f0, CTA principal WhatsApp #25d366.
 *
 * Estrutura: Hero → Informações de contato + Formulário → CTA WhatsApp (se configurado)
 */

import LocalLayout from '../../layouts/LocalLayout.astro';
import { getSiteContactInfo, formatPhone } from '../../utils/site-contact';

interface Props {
    data: Record<string, unknown>;
    siteName?: string;
}

const { data, siteName = 'Site' } = Astro.props;

const contact      = await getSiteContactInfo();
const heroTitle    = data?.heroTitle    || 'Entre em Contato';
const heroSubtitle = data?.heroSubtitle || '';
const email        = (data?.email as string | undefined) || '';
const phone        = (data?.phone as string | undefined) || contact.phone;
const address      = data?.address as string | undefined;
const formTitle   = data?.formTitle   || 'Envie sua Mensagem';
const formSubmitText = data?.formSubmitText || 'Enviar Mensagem';
const formSuccessMessage = data?.formSuccessMessage || 'Mensagem enviada com sucesso!';
const socialLinks = (data?.socialLinks as any[]) || [];

const whatsapp = contact.whatsapp;
const waMsg    = encodeURIComponent('Olá! Vim pelo site e gostaria de mais informações.');
const waUrl    = whatsapp ? `https://wa.me/55${whatsapp}?text=${waMsg}` : '#';
---

<LocalLayout
    title={`${heroTitle} - ${siteName}`}
    description={heroSubtitle || `Entre em contato com ${siteName}. Estamos prontos para atender.`}
>

    <!-- HERO -->
    <section style="background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1e40af 100%); padding: 5rem 1.5rem 4rem; text-align: center;">
        <div class="container mx-auto max-w-4xl">
            <div style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1.25rem; border-radius: 999px; background: rgba(37,99,235,0.2); border: 1px solid rgba(37,99,235,0.4); margin-bottom: 1.5rem;">
                <span style="font-size: 0.85rem; font-weight: 600; color: #93c5fd;">Fale Conosco</span>
            </div>
            <h1 style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; color: #fff; line-height: 1.2; margin-bottom: 1.25rem; font-family: 'Outfit', sans-serif;">
                {heroTitle}
            </h1>
            {heroSubtitle && (
                <p style="font-size: clamp(1rem, 2.5vw, 1.2rem); color: #94a3b8; max-width: 600px; margin: 0 auto 2rem; line-height: 1.7;">
                    {heroSubtitle}
                </p>
            )}
        </div>
    </section>

    <!-- INFORMAÇÕES + FORMULÁRIO -->
    <section style="padding: 4rem 1.5rem; background: #f8fafc;">
        <div class="container mx-auto">
            <div class="local-contato-grid">
                <!-- Informações de Contato -->
                <div style="display: flex; flex-direction: column; gap: 2rem;">
                    <div style="padding: 2rem; border-radius: 14px; background: #fff; border: 1px solid #e2e8f0;">
                        <h2 style="font-size: 1.5rem; font-weight: 800; color: #0f172a; margin-bottom: 1.5rem; font-family: 'Outfit', sans-serif;">
                            Informações de Contato
                        </h2>

                        {email && (
                            <div style="display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.25rem;">
                                <div style="width: 48px; height: 48px; border-radius: 12px; background: #dbeafe; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0;">📧</div>
                                <div>
                                    <p style="font-size: 0.8rem; color: #64748b; margin-bottom: 0.25rem;">E-mail</p>
                                    <a href={`mailto:${email}`} style="color: var(--primary, #2563eb); font-weight: 600; text-decoration: none;">{email}</a>
                                </div>
                            </div>
                        )}

                        {phone && (
                            <div style="display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.25rem;">
                                <div style="width: 48px; height: 48px; border-radius: 12px; background: #dbeafe; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0;">📞</div>
                                <div>
                                    <p style="font-size: 0.8rem; color: #64748b; margin-bottom: 0.25rem;">Telefone</p>
                                    <a href={`tel:+55${String(phone).replace(/\D/g, '')}`} style="color: var(--primary, #2563eb); font-weight: 600; text-decoration: none;">{phone}</a>
                                </div>
                            </div>
                        )}

                        {address && (
                            <div style="display: flex; align-items: flex-start; gap: 1rem;">
                                <div style="width: 48px; height: 48px; border-radius: 12px; background: #dbeafe; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0;">📍</div>
                                <div>
                                    <p style="font-size: 0.8rem; color: #64748b; margin-bottom: 0.25rem;">Endereço</p>
                                    <p style="color: #0f172a; white-space: pre-line; line-height: 1.6;">{address}</p>
                                </div>
                            </div>
                        )}

                        {!email && !phone && !address && (
                            <p style="color: #64748b; font-size: 0.9rem;">Configure os dados de contato no painel administrativo.</p>
                        )}
                    </div>

                    {socialLinks.length > 0 && (
                        <div style="padding: 2rem; border-radius: 14px; background: #fff; border: 1px solid #e2e8f0;">
                            <h3 style="font-size: 1.25rem; font-weight: 800; color: #0f172a; margin-bottom: 1.25rem; font-family: 'Outfit', sans-serif;">
                                Redes Sociais
                            </h3>
                            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                                {socialLinks.map((social: any) => (
                                    <a
                                        href={social.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        style="display: flex; align-items: center; gap: 1rem; padding: 1rem; border-radius: 10px; background: #f8fafc; border: 1px solid #e2e8f0; text-decoration: none; transition: all 0.2s;"
                                        class="local-contato-social-link"
                                    >
                                        <span style="font-size: 1.25rem;">{social.icon || '🔗'}</span>
                                        <span style="font-weight: 600; color: #0f172a;">{social.platform}</span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    )}
                </div>

                <!-- Formulário -->
                <div style="padding: 2rem; border-radius: 14px; background: #fff; border: 1px solid #e2e8f0;">
                    <h2 style="font-size: 1.5rem; font-weight: 800; color: #0f172a; margin-bottom: 1.5rem; font-family: 'Outfit', sans-serif;">
                        {formTitle}
                    </h2>
                    <form class="local-contato-form" id="local-contact-form" onsubmit="return false;">
                        <div style="margin-bottom: 1.25rem;">
                            <label for="local-name" style="display: block; font-size: 0.875rem; font-weight: 600; color: #334155; margin-bottom: 0.5rem;">Nome</label>
                            <input
                                type="text"
                                id="local-name"
                                name="name"
                                required
                                style="width: 100%; padding: 0.75rem 1rem; border-radius: 10px; border: 1px solid #e2e8f0; font-size: 1rem; color: #0f172a; background: #fff;"
                                placeholder="Seu nome completo"
                            />
                        </div>
                        <div style="margin-bottom: 1.25rem;">
                            <label for="local-email" style="display: block; font-size: 0.875rem; font-weight: 600; color: #334155; margin-bottom: 0.5rem;">E-mail</label>
                            <input
                                type="email"
                                id="local-email"
                                name="email"
                                required
                                style="width: 100%; padding: 0.75rem 1rem; border-radius: 10px; border: 1px solid #e2e8f0; font-size: 1rem; color: #0f172a; background: #fff;"
                                placeholder="seu@email.com"
                            />
                        </div>
                        <div style="margin-bottom: 1.25rem;">
                            <label for="local-message" style="display: block; font-size: 0.875rem; font-weight: 600; color: #334155; margin-bottom: 0.5rem;">Mensagem</label>
                            <textarea
                                id="local-message"
                                name="message"
                                required
                                rows="5"
                                style="width: 100%; padding: 0.75rem 1rem; border-radius: 10px; border: 1px solid #e2e8f0; font-size: 1rem; color: #0f172a; background: #fff; resize: none;"
                                placeholder="Como podemos ajudar?"
                            ></textarea>
                        </div>
                        <button
                            type="submit"
                            style="width: 100%; padding: 1rem 1.5rem; border-radius: 999px; background: #25d366; color: #fff; font-weight: 700; font-size: 1rem; border: none; cursor: pointer; box-shadow: 0 4px 24px rgba(37,211,102,0.35); transition: opacity 0.2s;"
                        >
                            {formSubmitText}
                        </button>
                        <div id="local-form-message" class="local-form-message"></div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA WHATSAPP -->
    {waUrl !== '#' && (
        <section style="padding: 4rem 1.5rem; background: linear-gradient(135deg, #1e3a5f 0%, #1e40af 100%); text-align: center;">
            <div class="container mx-auto max-w-2xl">
                <h2 style="font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 800; color: #fff; margin-bottom: 0.75rem; font-family: 'Outfit', sans-serif;">
                    Prefere conversar direto?
                </h2>
                <p style="font-size: 1rem; color: #93c5fd; margin-bottom: 1.5rem; line-height: 1.6;">
                    Atendimento rápido pelo WhatsApp. Resposta em minutos!
                </p>
                <a
                    href={waUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    style="display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2rem; border-radius: 999px; background: #25d366; color: #fff; font-weight: 700; font-size: 1rem; text-decoration: none; box-shadow: 0 6px 30px rgba(37,211,102,0.4); transition: opacity 0.2s;"
                >
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                    Chamar no WhatsApp
                </a>
            </div>
        </section>
    )}

    <script define:vars={{ formSuccessMessage }}>
        const form = document.getElementById('local-contact-form');
        const msgEl = document.getElementById('local-form-message');
        const submitBtn = form?.querySelector('button[type="submit"]');

        if (form && msgEl) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                var nameEl = form.querySelector('[name="name"]');
                var emailEl = form.querySelector('[name="email"]');
                var messageEl = form.querySelector('[name="message"]');
                var name = (nameEl && nameEl.value ? nameEl.value : '').toString().trim();
                var email = (emailEl && emailEl.value ? emailEl.value : '').toString().trim();
                var message = (messageEl && messageEl.value ? messageEl.value : '').toString().trim();

                msgEl.innerHTML = '⏳ Enviando sua mensagem...';
                msgEl.style.cssText = 'display:block; margin-top:1rem; padding:1rem; border-radius:10px; background:#e0f2fe; color:#0369a1; border:1px solid #7dd3fc;';
                submitBtn?.setAttribute('disabled', 'true');

                try {
                    var res = await fetch('/api/leads', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ name: name, email: email, message: message, source: 'local-contato' }),
                    });
                    var data = await res.json();

                    if (data.success) {
                        msgEl.innerHTML = '✅ ' + (formSuccessMessage || 'Mensagem enviada com sucesso! Recebemos seu contato e retornaremos em breve.');
                        msgEl.style.cssText = 'display:block; margin-top:1rem; padding:1rem; border-radius:10px; background:#dcfce7; color:#166534; border:1px solid #86efac;';
                        form.reset();
                    } else {
                        msgEl.innerHTML = '❌ ' + (data.error || 'Erro ao enviar. Tente novamente.');
                        msgEl.style.cssText = 'display:block; margin-top:1rem; padding:1rem; border-radius:10px; background:#fee2e2; color:#b91c1c; border:1px solid #fca5a5;';
                    }
                } catch (err) {
                    msgEl.innerHTML = '❌ Erro de conexão. Verifique sua internet e tente novamente.';
                    msgEl.style.cssText = 'display:block; margin-top:1rem; padding:1rem; border-radius:10px; background:#fee2e2; color:#b91c1c; border:1px solid #fca5a5;';
                }
                submitBtn?.removeAttribute('disabled');
                setTimeout(function() { msgEl.style.display = 'none'; }, 6000);
            });
        }
    </script>
</LocalLayout>

<style>
    .local-contato-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        max-width: 1000px;
        margin: 0 auto;
    }
    .local-contato-social-link:hover {
        border-color: var(--primary, #2563eb) !important;
        background: #eff6ff !important;
    }
    .local-form-message {
        display: none;
    }
    @media (max-width: 768px) {
        .local-contato-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
