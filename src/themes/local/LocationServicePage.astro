        <div class="container mx-auto lsp-hero-inner">

            <!-- Badge localização -->
            <div class="lsp-hero-badge">
                <span>📍 {location.name}{location.city && location.city !== location.name ? ` · ${location.city}` : ''} — {location.state}</span>
            </div>

