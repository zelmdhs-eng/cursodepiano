                                    <div class="faq-item lsp-faq-item">
                                        <details>
                                            <summary class="lsp-faq-summary">
                                                <span>{item.q}</span>
                                                <span class="faq-arrow lsp-faq-arrow">▼</span>
                                            </summary>
                                            <div class="lsp-faq-answer">{item.a}</div>
                                        </details>
                                    </div>
