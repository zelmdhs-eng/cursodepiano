        <div class="container mx-auto">
            <a href="/" class="lsp-breadcrumb-link">Início</a>
            <span class="lsp-breadcrumb-sep">›</span>
            <a href={`/${location.slug}`} class="lsp-breadcrumb-link">{location.name}</a>
            <span class="lsp-breadcrumb-sep">›</span>
