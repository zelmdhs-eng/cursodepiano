---
/**
 * Footer.astro (Classic Theme)
 * 
 * Componente de rodapé do tema Classic.
 * Lê os dados do singleton 'footer' para renderizar o rodapé dinamicamente.
 */

import { readSingleton } from '../../../utils/singleton-utils';

const { activeThemeId } = Astro.props;
const year = new Date().getFullYear();

// Carregar dados do rodapé do singleton do tema ativo
const footerData = await readSingleton('footer', activeThemeId);
const copyright = footerData?.copyright || `© ${year} Curso de Piano - Built with Astro Structural Themes.`;
const description = footerData?.description || 'Transformando ideias em interfaces de alto impacto com Astro, Keystatic e Inteligência Artificial.';
const columns = footerData?.columns || [];
const socialLinks = footerData?.socialLinks || [];
---

<footer class="bg-[#0a0a0a] border-t border-white/5 py-20 px-6">
    <div class="container mx-auto">
        <div class="grid md:grid-cols-4 gap-12 mb-16">
            <div class="col-span-2">
                <div class="text-2xl font-heading font-black text-white mb-6 bg-clip-text text-transparent bg-gradient-to-r from-primary to-secondary">
                    {footerData?.title || 'Curso de Piano'}
                </div>
                <p class="text-slate-500 max-w-sm leading-relaxed">{description}</p>
            </div>
            {columns.map((column: any) => (
                <div>
                    <h4 class="text-white font-bold mb-6 uppercase tracking-widest text-xs">{column.title}</h4>
                    <ul class="space-y-4 text-sm text-slate-500">
                        {(column.links || []).map((link: any) => (
                            <li>
                                <a href={link.href} class="hover:text-primary transition-colors">{link.label}</a>
                            </li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>
        <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-600 font-medium whitespace-nowrap overflow-hidden">
            <p>{copyright}</p>
            <div class="flex gap-6 uppercase tracking-widest items-center">
                {socialLinks.length > 0 && (
                    <div class="flex gap-4">
                        {socialLinks.map((social: any) => (
                            <a 
                                href={social.url} 
                                target="_blank"
                                rel="noopener noreferrer"
                                class="hover:text-primary transition-colors"
                                title={social.platform}
                            >
                                {social.platform === 'Instagram' && (
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                                )}
                                {social.platform === 'YouTube' && (
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
                                )}
                                {social.platform !== 'Instagram' && social.platform !== 'YouTube' && (
                                    social.icon || social.platform
                                )}
                            </a>
                        ))}
                    </div>
                )}
            </div>
        </div>
    </div>
</footer>
