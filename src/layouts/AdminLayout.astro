---
/**
 * AdminLayout.astro
 * 
 * Layout base para todas as páginas do painel administrativo.
 * Fornece estrutura com sidebar fixa, header e área de conteúdo principal.
 * Design moderno e profissional, rival do WordPress em UX mas superior em performance.
 * 
 * Componentes incluídos:
 * - Sidebar de navegação fixa
 * - Header com busca e ações rápidas
 * - Área de conteúdo responsiva
 * - Sistema de cores dinâmico baseado no tema ativo
 */

import AdminSidebar from '../components/admin/Sidebar.astro';
import AdminHeader from '../components/admin/Header.astro';
import { verifySession, SESSION_COOKIE } from '../utils/auth-utils';
import { getAdminSiteMode } from '../utils/admin-site-mode';
import { getEntry } from 'astro:content';
import '../styles/global.css';
import '../styles/admin.css';
import '@fontsource/inter';
import '@fontsource/outfit';

interface Props {
    title?: string;
    description?: string;
}

const { 
    title = "Painel Administrativo",
    description = "Gerencie seu site com facilidade e performance"
} = Astro.props;

// Verificar sessão DIRETAMENTE do cookie — não depende do middleware
const token = Astro.cookies.get(SESSION_COOKIE)?.value;
const currentUser = token ? verifySession(token) : null;

// Redirecionar para login se não autenticado
if (!currentUser) {
    return Astro.redirect('/admin/login');
}

const settings  = await getEntry('siteSettings', 'settings').catch(() => null);
const siteMode  = getAdminSiteMode(Astro.cookies, settings);
const isLocal   = siteMode === 'local';

const primaryColor = '#a855f7';
const secondaryColor = '#ec4899';
const borderRadius = '16px';

// Helper para converter hex para RGB
function hexToRgb(hex: string) {
    if (!hex || typeof hex !== 'string' || !hex.startsWith('#')) return '168 85 247';
    try {
        const r = parseInt(hex.slice(1, 3), 16);
        const g = parseInt(hex.slice(3, 5), 16);
        const b = parseInt(hex.slice(5, 7), 16);
        if (isNaN(r) || isNaN(g) || isNaN(b)) return '168 85 247';
        return `${r} ${g} ${b}`;
    } catch {
        return '168 85 247';
    }
}

const primaryRGB = hexToRgb(primaryColor);
const secondaryRGB = hexToRgb(secondaryColor);
---

<!doctype html>
<html lang="pt-BR" class="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content={description} />

        <!-- Theme Variables -->
        <style is:global define:vars={{ primaryRGB, secondaryRGB, borderRadius }}>
            :root {
                --primary-rgb: var(--primaryRGB);
                --secondary-rgb: var(--secondaryRGB);
                --radius: var(--borderRadius);
            }
        </style>

        <!-- Anti-flash: aplica o tema salvo ANTES de renderizar qualquer pixel -->
        <script is:inline>
            (function () {
                try {
                    var saved = localStorage.getItem('cnx-theme');
                    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                    var theme = saved || (prefersDark ? 'dark' : 'light');
                    var html = document.documentElement;
                    html.classList.remove('dark', 'light');
                    html.classList.add(theme);
                } catch (e) {}
            })();
        </script>
    </head>
    <body class="font-sans antialiased min-h-screen" style="background: var(--admin-bg); color: var(--admin-text);">
        <!-- Background -->
        <div class="fixed inset-0 -z-10 h-full w-full" style="background: var(--admin-bg);"></div>

        <div class="flex h-screen overflow-hidden" data-site-mode={siteMode}>
            <!-- Sidebar -->
            <AdminSidebar user={currentUser} />

            <!-- Main Content Area -->
            <div class="flex flex-col flex-1 overflow-hidden admin-main-area">
                <!-- Header -->
                <AdminHeader user={currentUser} siteMode={siteMode} />

                <!-- Banner de atualização do template (visível em todas as páginas do admin) -->
                <div id="version-update-banner" class="hidden mx-6 lg:mx-8 mt-4 mb-4 rounded-xl overflow-hidden flex-shrink-0" style="border: 1px solid rgba(234,179,8,0.4); background: linear-gradient(135deg, rgba(234,179,8,0.08) 0%, rgba(234,179,8,0.04) 100%);">
                    <div class="flex items-center justify-between flex-wrap gap-4 p-4">
                        <div class="flex items-center gap-3">
                            <div class="flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center text-lg" style="background: rgba(234,179,8,0.15);">🔔</div>
                            <div>
                                <div class="text-sm font-bold" style="color: #fbbf24;" id="update-banner-title">Nova versão disponível</div>
                                <div class="text-xs mt-0.5" style="color: #a3a3a3;" id="update-banner-subtitle">Clique em &quot;Aplicar agora&quot; para atualizar com 1 clique</div>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 flex-shrink-0">
                            <a id="update-banner-changelog" href="#" target="_blank" class="hidden text-xs px-3 py-1.5 rounded-lg transition-all" style="border: 1px solid rgba(234,179,8,0.25); color: #fbbf24; text-decoration: none;">
                                Ver novidades →
                            </a>
                            <button
                                id="version-update-btn"
                                class="text-xs px-5 py-2 rounded-lg font-bold transition-all flex items-center gap-2"
                                style="background: rgba(234,179,8,0.2); border: 1px solid rgba(234,179,8,0.45); color: #fbbf24;"
                            >
                                🔄 Aplicar agora
                            </button>
                        </div>
                    </div>
                    <div id="version-update-status" class="hidden px-4 pb-4">
                        <div id="version-update-status-inner" class="text-xs px-3 py-2 rounded-lg"></div>
                    </div>
                </div>

                <!-- Page Content -->
                <main class="flex-1 overflow-y-auto p-6 lg:p-8">
                    <slot />
                </main>
            </div>
        </div>

        <!-- Verificação de versão do template (em todas as páginas do admin) -->
        <script is:inline>
        (function () {
            var badgeIcon = document.getElementById('version-badge-icon');
            var badgeText = document.getElementById('version-badge-text');
            var badge = document.getElementById('version-badge');
            var banner = document.getElementById('version-update-banner');
            var bannerTitle = document.getElementById('update-banner-title');
            var bannerSub = document.getElementById('update-banner-subtitle');
            var changelog = document.getElementById('update-banner-changelog');
            var updateBtn = document.getElementById('version-update-btn');
            var statusWrap = document.getElementById('version-update-status');
            var statusInner = document.getElementById('version-update-status-inner');

            fetch('/api/admin/version')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.upToDate) {
                        if (badgeIcon) badgeIcon.textContent = '✅';
                        if (badgeText) {
                            badgeText.textContent = 'v' + data.installed;
                            badgeText.style.color = 'var(--admin-text-subtle)';
                        }
                    } else {
                        if (badgeIcon) badgeIcon.textContent = '🔔';
                        if (badgeText) {
                            badgeText.textContent = 'v' + data.installed + ' → v' + data.latest;
                            badgeText.style.color = '#fbbf24';
                            badgeText.style.fontWeight = '600';
                        }
                        if (badge) {
                            badge.style.borderColor = 'rgba(234,179,8,0.35)';
                            badge.style.background = 'rgba(234,179,8,0.08)';
                        }
                        if (bannerTitle) bannerTitle.textContent = '🔔 Nova versão: v' + data.installed + ' → v' + data.latest;
                        if (banner) banner.classList.remove('hidden');
                        if (changelog && data.changelog) {
                            changelog.href = data.changelog;
                            changelog.classList.remove('hidden');
                        }
                    }
                })
                .catch(function () {
                    if (badgeIcon) badgeIcon.textContent = '❓';
                    if (badgeText) badgeText.textContent = 'versão desconhecida';
                });

            if (updateBtn) {
                updateBtn.addEventListener('click', function () {
                    updateBtn.disabled = true;
                    updateBtn.innerHTML = '⏳ Iniciando...';
                    updateBtn.style.opacity = '0.6';
                    updateBtn.style.cursor = 'not-allowed';

                    fetch('/api/admin/version/update', { method: 'POST' })
                        .then(function (r) { return r.json(); })
                        .then(function (res) {
                            if (statusWrap) statusWrap.classList.remove('hidden');
                            if (res.success) {
                                if (statusInner) {
                                    statusInner.style.background = 'rgba(74,222,128,0.08)';
                                    statusInner.style.border = '1px solid rgba(74,222,128,0.2)';
                                    statusInner.style.color = '#86efac';
                                    statusInner.textContent = '✅ ' + res.message;
                                }
                                if (updateBtn) updateBtn.classList.add('hidden');
                                if (bannerTitle) bannerTitle.textContent = '⏳ Atualização em andamento...';
                                if (bannerSub) bannerSub.textContent = 'Aguarde ~2 minutos. O site será reconstruído automaticamente.';
                                if (badgeIcon) badgeIcon.textContent = '⏳';
                                if (badgeText) badgeText.textContent = 'atualizando...';
                            } else {
                                if (statusInner) {
                                    statusInner.style.background = 'rgba(239,68,68,0.08)';
                                    statusInner.style.border = '1px solid rgba(239,68,68,0.2)';
                                    statusInner.style.color = '#fca5a5';
                                    var errHtml = '❌ ' + (res.error || 'Erro desconhecido.');
                                    if (res.helpUrl) {
                                        errHtml += ' <a href="' + res.helpUrl + '" target="_blank" rel="noopener noreferrer" style="color:#fbbf24;text-decoration:underline;margin-left:4px;">Abrir configurações do GitHub →</a>';
                                    }
                                    statusInner.innerHTML = errHtml;
                                }
                                updateBtn.disabled = false;
                                updateBtn.innerHTML = '🔄 Tentar novamente';
                                updateBtn.style.opacity = '1';
                                updateBtn.style.cursor = 'pointer';
                            }
                        })
                        .catch(function () {
                            if (statusWrap) statusWrap.classList.remove('hidden');
                            if (statusInner) {
                                statusInner.style.background = 'rgba(239,68,68,0.08)';
                                statusInner.style.border = '1px solid rgba(239,68,68,0.2)';
                                statusInner.style.color = '#fca5a5';
                                statusInner.textContent = '❌ Erro de rede. Tente novamente.';
                            }
                            updateBtn.disabled = false;
                            updateBtn.innerHTML = '🔄 Tentar novamente';
                            updateBtn.style.opacity = '1';
                            updateBtn.style.cursor = 'pointer';
                        });
                });
            }
        })();
        </script>
    </body>
</html>
